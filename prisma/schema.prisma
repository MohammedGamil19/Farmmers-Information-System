generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  ADMIN
  FARMER
}

enum MemberStatus {
  ACTIVE
  INACTIVE
  PENDING
}

enum FarmStatus {
  ACTIVE
  GROWING
  READY_FOR_HARVEST
  HARVESTED
}

enum CropStage {
  SEEDLING
  VEGETATIVE
  GROWING
  READY_FOR_HARVEST
  HARVESTED
}

enum OwnershipStatus {
  OWNED
  RENTED
  MORTGAGED
}

enum NotificationType {
  ABNORMAL_PH
  ABNORMAL_TDS
  UPCOMING_HARVEST
  MISSING_RECORD
  SYSTEM
}

enum AnnouncementType {
  INFO
  WARNING
  EVENT
}

enum EventCategory {
  PLANTING
  HARVEST
  MEETING
  TRAINING
  OTHER
}

model User {
  id           String       @id @default(cuid())
  name         String
  email        String       @unique
  password     String
  role         Role         @default(FARMER)
  phone        String?
  avatar       String?
  nik          String?      @unique
  address      String?
  rt           String?
  rw           String?
  memberStatus MemberStatus @default(ACTIVE)
  isActive     Boolean      @default(true)
  lastLoginAt  DateTime?
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  villageId      String?
  village        Village?      @relation(fields: [villageId], references: [id])

  farms          Farm[]
  notifications  Notification[]
  plantTypes     PlantType[]
  lahans         Lahan[]
  announcements  Announcement[]
  calendarEvents CalendarEvent[]
  panens         Panen[]
  activityLogs   ActivityLog[]

  @@map("users")
}

model Village {
  id          String   @id @default(cuid())
  name        String
  district    String
  province    String
  description String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  users          User[]
  farms          Farm[]
  lahans         Lahan[]
  announcements  Announcement[]
  calendarEvents CalendarEvent[]
  panens         Panen[]

  @@map("villages")
}

model PlantType {
  id          String   @id @default(cuid())
  name        String   @unique
  description String?
  growthDays  Int      @default(30)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  createdById String?
  createdBy   User?   @relation(fields: [createdById], references: [id])

  farms  Farm[]
  panens Panen[]

  @@map("plant_types")
}

model Farm {
  id               String     @id @default(cuid())
  name             String
  description      String?
  location         String?
  area             Float?
  status           FarmStatus @default(ACTIVE)
  cropStage        CropStage  @default(SEEDLING)
  plantingDate     DateTime
  estimatedHarvest DateTime?
  actualHarvest    DateTime?
  isActive         Boolean    @default(true)
  createdAt        DateTime   @default(now())
  updatedAt        DateTime   @updatedAt

  ownerId     String
  owner       User      @relation(fields: [ownerId], references: [id])
  villageId   String
  village     Village   @relation(fields: [villageId], references: [id])
  plantTypeId String
  plantType   PlantType @relation(fields: [plantTypeId], references: [id])

  panens Panen[]

  @@map("farms")
}

model Lahan {
  id              String          @id @default(cuid())
  area            Float
  blockLocation   String?
  soilType        String?
  ownershipStatus OwnershipStatus @default(OWNED)
  commodity       String?
  description     String?
  isActive        Boolean         @default(true)
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  ownerId   String
  owner     User    @relation(fields: [ownerId], references: [id])
  villageId String
  village   Village @relation(fields: [villageId], references: [id])

  @@map("lahans")
}

model Notification {
  id        String           @id @default(cuid())
  title     String
  message   String
  type      NotificationType
  isRead    Boolean          @default(false)
  createdAt DateTime         @default(now())

  userId String
  user   User   @relation(fields: [userId], references: [id])

  @@map("notifications")
}

model Announcement {
  id          String           @id @default(cuid())
  title       String
  content     String
  type        AnnouncementType @default(INFO)
  isPublished Boolean          @default(true)
  publishedAt DateTime         @default(now())
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  authorId  String
  author    User    @relation(fields: [authorId], references: [id])
  villageId String
  village   Village @relation(fields: [villageId], references: [id])

  @@map("announcements")
}

model CalendarEvent {
  id          String        @id @default(cuid())
  title       String
  description String?
  startDate   DateTime
  endDate     DateTime?
  category    EventCategory @default(OTHER)
  location    String?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  villageId   String
  village     Village @relation(fields: [villageId], references: [id])
  createdById String
  createdBy   User    @relation(fields: [createdById], references: [id])

  @@map("calendar_events")
}

model Panen {
  id            String   @id @default(cuid())
  tanggalPanen  DateTime
  komoditas     String
  jumlahKg      Float
  hargaJual     Float?
  kondisi       String   @default("Baik")
  catatan       String?
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  farmId      String
  farm        Farm      @relation(fields: [farmId], references: [id])
  plantTypeId String
  plantType   PlantType @relation(fields: [plantTypeId], references: [id])
  petaniId    String
  petani      User      @relation(fields: [petaniId], references: [id])
  villageId   String
  village     Village   @relation(fields: [villageId], references: [id])

  @@map("panens")
}

model ActivityLog {
  id        String   @id @default(cuid())
  action    String   // CREATE | UPDATE | DELETE
  entity    String   // Panen | Anggota | Lahan | Kebun | Pengguna
  detail    String   // human-readable Indonesian description
  villageId String?
  createdAt DateTime @default(now())

  userId String
  user   User   @relation(fields: [userId], references: [id])

  @@index([villageId, createdAt])
  @@map("activity_logs")
}

model SystemSetting {
  id        String   @id @default(cuid())
  key       String   @unique
  value     String
  updatedAt DateTime @updatedAt

  @@map("system_settings")
}
